# 기존 Next.js 프로젝트의 .env에서 그대로 복사하시면 됩니다.
# Supabase 대시보드 > Settings > API 에서 확인 가능합니다.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....

# 중앙 크롤링 서버 (lawbot-crawler)
VITE_CRAWLER_URL=https://crawler.law-bot-api.com
# 크롤러 서버의 CRON_SECRET과 동일한 값
VITE_CRAWLER_SECRET=
