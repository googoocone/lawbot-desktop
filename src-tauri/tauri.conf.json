{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "law-bot 사건관리 프로그램",
  "version": "0.1.0",
  "identifier": "com.caseflow.desktop",
  "build": {
    "beforeDevCommand": "node node_modules/vite/bin/vite.js",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node node_modules/typescript/bin/tsc && node node_modules/vite/bin/vite.js build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "law-bot 사건관리 프로그램",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "windows": {
      "wix": {
        "language": "ko-KR"
      },
      "nsis": {
        "languages": ["Korean"]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/googoocone/lawbot-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJCMjVCNEZGQTVGNDU3NzEKUldSeFYvU2wvN1FsdXlXTVUwV0FQSkdpYmpqYjEvREtrcmE3TWtlTGFpWmRSM1dGT00rbmIxSkQK"
    }
  }
}
